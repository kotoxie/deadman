# Server
PORT=6680

# ─── REQUIRED: App will refuse to start without these ─────────────
# Master password for login (must be strong, NOT a common word)
MASTER_PASSWORD=<REPLACE: choose a strong unique password>

# Session signing key (generate with: openssl rand -hex 32)
SESSION_SECRET=<REPLACE: run openssl rand -hex 32>

# Database encryption key (generate with: openssl rand -hex 32)
# WARNING: SESSION_SECRET and DB_ENCRYPTION_KEY must be DIFFERENT values
DB_ENCRYPTION_KEY=<REPLACE: run openssl rand -hex 32>

# ─── Optional ─────────────────────────────────────────────────────
# Data directory (inside container: /app/data)
# DATA_DIR=./data

# Set to true when behind HTTPS reverse proxy
# SECURE_COOKIES=false

# Log level: error, warn, info, debug
# LOG_LEVEL=info

# SMTP (can also configure via Settings UI)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=false

# Telegram (can also configure via Settings UI)
# TELEGRAM_BOT_TOKEN=
