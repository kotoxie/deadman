# Server
PORT=6680
NODE_ENV=production

# Authentication - MUST change in production (app will refuse to start with defaults)
MASTER_PASSWORD=change_me_to_a_strong_password

# Security - MUST change in production (use: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_random_64_char_string
DB_ENCRYPTION_KEY=change_me_to_a_random_64_char_string

# Data directory (inside container: /app/data)
DATA_DIR=./data

# Optional: SMTP (can also configure via Settings UI)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=false

# Optional: Telegram (can also configure via Settings UI)
# TELEGRAM_BOT_TOKEN=
